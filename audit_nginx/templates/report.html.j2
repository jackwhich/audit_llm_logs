<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Nginx 审计报告</title>
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif; margin: 24px; color: #111; }
      .muted { color: #666; }
      .card { border: 1px solid #eee; border-radius: 10px; padding: 16px; margin: 12px 0; }
      .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
      h1 { margin: 0 0 8px; }
      h2 { margin: 18px 0 8px; }
      table { width: 100%; border-collapse: collapse; }
      th, td { border-bottom: 1px solid #eee; padding: 8px; text-align: left; vertical-align: top; font-size: 13px; }
      th { background: #fafafa; position: sticky; top: 0; }
      .sev { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 12px; }
      .sev-critical { background: #fee2e2; color: #991b1b; }
      .sev-high { background: #ffedd5; color: #9a3412; }
      .sev-medium { background: #fef9c3; color: #854d0e; }
      .sev-low { background: #e0f2fe; color: #075985; }
      .code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace; font-size: 12px; }
      pre { background: #0b1020; color: #e5e7eb; padding: 12px; border-radius: 10px; overflow: auto; }
      .bar { height: 10px; background: #eee; border-radius: 999px; overflow: hidden; }
      .bar > div { height: 10px; background: #111; }
      @media (max-width: 960px) { .grid { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <h1>Nginx 日志审计报告</h1>
    <div class="muted">
      时间窗口（{{ report_time.timezone }}）：{{ report_time.start }} ~ {{ report_time.end }}<br/>
      ES：{{ es_cfg.url }}，索引：<span class="code">{{ es_cfg.index_pattern }}</span>，时间字段：<span class="code">{{ es_cfg.time_field }}</span><br/>
      拉取：{{ meta.fetched_docs }}，规范化：{{ meta.normalized_events }}{% if meta.dry_run %}（dry-run）{% endif %}
    </div>

    {% if llm_summary %}
    <h2>执行摘要（LLM）</h2>
    <div class="card">
      <pre style="white-space: pre-wrap">{{ llm_summary }}</pre>
    </div>
    {% endif %}

    {% if per_event_ai %}
    <h2>全量事件 AI 审计（汇总）</h2>
    <div class="grid">
      <div class="card">
        <div class="muted">风险等级分布</div>
        <table>
          <thead><tr><th>risk_level</th><th>count</th></tr></thead>
          <tbody>
            {% for k,v in per_event_ai.risk_level_counts %}
              <tr><td class="code">{{ k }}</td><td>{{ v }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="card">
        <div class="muted">分类分布</div>
        <table>
          <thead><tr><th>category</th><th>count</th></tr></thead>
          <tbody>
            {% for k,v in per_event_ai.category_counts %}
              <tr><td class="code">{{ k }}</td><td>{{ v }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="card">
        <div class="muted">Top Tags</div>
        <table>
          <thead><tr><th>tag</th><th>count</th></tr></thead>
          <tbody>
            {% for k,v in per_event_ai.top_tags %}
              <tr><td class="code">{{ k }}</td><td>{{ v }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="card">
        <div class="muted">全量结果侧边文件（jsonl）</div>
        {% if per_event_ai.jsonl_path %}
          <div class="code">{{ per_event_ai.jsonl_path }}</div>
        {% else %}
          <div class="muted">未启用落盘</div>
        {% endif %}
      </div>
    </div>

    <h2>全量事件 AI 审计（样本展示）</h2>
    <div class="card">
      <div class="muted">说明：全量事件很多时 HTML 会非常大，因此这里只展示前 {{ per_event_ai.sample_size }} 条；完整结果在 jsonl 文件里。</div>
      <table>
        <thead><tr><th>ts</th><th>ip</th><th>path</th><th>status</th><th>risk</th><th>category</th><th>summary</th><th>tags</th></tr></thead>
        <tbody>
          {% for row in per_event_ai.samples %}
          <tr>
            <td class="code">{{ row.event.ts }}</td>
            <td class="code">{{ row.event.ip }}</td>
            <td class="code">{{ row.event.path }}</td>
            <td class="code">{{ row.event.status }}</td>
            <td class="code">{{ row.ai.risk_level }}</td>
            <td class="code">{{ row.ai.category }}</td>
            <td>{{ row.ai.summary }}</td>
            <td class="code">{{ row.ai.tags }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    <h2>关键指标</h2>
    <div class="grid">
      <div class="card">
        <div class="muted">总请求数</div>
        <div style="font-size:28px;font-weight:700">{{ stats.total_events }}</div>
      </div>
      <div class="card">
        <div class="muted">状态码分布（Top）</div>
        <table>
          <thead><tr><th>status</th><th>count</th></tr></thead>
          <tbody>
            {% for k,v in stats.status_counts_top %}
              <tr><td class="code">{{ k }}</td><td>{{ v }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    <h2>Top 访问来源 / 路径 / UA</h2>
    <div class="grid">
      <div class="card">
        <div class="muted">Top IP</div>
        <table>
          <thead><tr><th>ip</th><th>count</th></tr></thead>
          <tbody>
            {% for ip,c in stats.top_ips %}
              <tr><td class="code">{{ ip }}</td><td>{{ c }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="card">
        <div class="muted">Top Path</div>
        <table>
          <thead><tr><th>path</th><th>count</th></tr></thead>
          <tbody>
            {% for p,c in stats.top_paths %}
              <tr><td class="code">{{ p }}</td><td>{{ c }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="card">
        <div class="muted">Top User-Agent</div>
        <table>
          <thead><tr><th>ua</th><th>count</th></tr></thead>
          <tbody>
            {% for ua,c in stats.top_user_agents %}
              <tr><td class="code">{{ ua }}</td><td>{{ c }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="card">
        <div class="muted">可疑敏感路径命中</div>
        {% if stats.suspicious_path_hits %}
        <table>
          <thead><tr><th>path</th><th>count</th></tr></thead>
          <tbody>
            {% for p,c in stats.suspicious_path_hits %}
              <tr><td class="code">{{ p }}</td><td>{{ c }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
        {% else %}
        <div class="muted">无</div>
        {% endif %}
      </div>
    </div>

    <h2>运维异常摘要</h2>
    <div class="grid">
      <div class="card">
        <div class="muted">Top 5xx 路径</div>
        {% if stats.top_5xx_paths %}
        <table>
          <thead><tr><th>path</th><th>count</th></tr></thead>
          <tbody>
            {% for p,c in stats.top_5xx_paths %}
              <tr><td class="code">{{ p }}</td><td>{{ c }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
        {% else %}
        <div class="muted">无</div>
        {% endif %}
      </div>
      <div class="card">
        <div class="muted">慢请求样本（request_time >= 2s）</div>
        {% if stats.slow_requests %}
        <table>
          <thead><tr><th>ts</th><th>ip</th><th>path</th><th>status</th><th>rt</th><th>ut</th></tr></thead>
          <tbody>
            {% for e in stats.slow_requests %}
              <tr>
                <td class="code">{{ e.ts }}</td>
                <td class="code">{{ e.ip }}</td>
                <td class="code">{{ e.path }}</td>
                <td class="code">{{ e.status }}</td>
                <td class="code">{{ e.request_time }}</td>
                <td class="code">{{ e.upstream_time }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
        {% else %}
        <div class="muted">无或字段不可用</div>
        {% endif %}
      </div>
    </div>

    <h2>发现项（Findings）</h2>
    {% if findings %}
      {% for f in findings %}
      <div class="card">
        <div>
          {% set sev = f.severity %}
          <span class="sev sev-{{ sev }}">{{ sev }}</span>
          <b>{{ f.title }}</b> <span class="muted">（{{ f.category }}）</span>
        </div>
        <div class="muted" style="margin-top:6px">{{ f.description }}</div>
        <div style="margin-top:10px"><b>建议</b></div>
        <div class="muted">{{ f.recommendation }}</div>
        {% if f.evidence %}
          <div style="margin-top:10px"><b>证据样本</b></div>
          <table>
            <thead><tr><th>ts</th><th>ip</th><th>method</th><th>path</th><th>status</th><th>ua</th></tr></thead>
            <tbody>
              {% for e in f.evidence %}
              <tr>
                <td class="code">{{ e.ts }}</td>
                <td class="code">{{ e.ip }}</td>
                <td class="code">{{ e.method }}</td>
                <td class="code">{{ e.path }}</td>
                <td class="code">{{ e.status }}</td>
                <td class="code">{{ e.ua }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        {% endif %}
      </div>
      {% endfor %}
    {% else %}
      <div class="muted">未发现明显异常（或规则关闭）。</div>
    {% endif %}

    <hr style="border:0;border-top:1px solid #eee;margin:24px 0" />
    <div class="muted">Generated by audit_nginx</div>
  </body>
</html>
